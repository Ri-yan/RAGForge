# Application
APP_NAME=RAG Pipeline API
APP_VERSION=1.0.0
DEBUG=false

# Embedding
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Vector Store
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_collection

# Text Splitter
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LLM (Ollama)
LLM_TYPE=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Retrieval
RETRIEVAL_TOP_K=5

# Upload
UPLOAD_DIRECTORY=./data/uploads

# OCR
OCR_ENABLED=true
TESSERACT_LANG=eng
